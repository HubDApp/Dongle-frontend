# Copy this file to `.env.local` in the `dongle/` directory and customize as needed.
# See README.md "Environment Variables" for full documentation.

# ============================================
# SOROBAN SMART CONTRACTS (required in production)
# ============================================
# Stellar contract IDs (56 chars: C + 55 base32 characters).
# Development builds use placeholder defaults when unset.

NEXT_PUBLIC_PROJECT_REGISTRY_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
NEXT_PUBLIC_REVIEW_REGISTRY_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
NEXT_PUBLIC_VERIFICATION_REGISTRY_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ============================================
# STELLAR NETWORK CONFIGURATION (optional in dev)
# ============================================
# Soroban RPC endpoint. Default: Stellar testnet.
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443

# Network passphrase — must match the Freighter network selection.
NEXT_PUBLIC_SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ============================================
# ADMIN ACCESS CONTROL (optional)
# ============================================
# Comma-separated Stellar public keys (G...) allowed to use the admin dashboard.
# Leave empty to disable admin-only routes.
NEXT_PUBLIC_ADMIN_ALLOWLIST=
